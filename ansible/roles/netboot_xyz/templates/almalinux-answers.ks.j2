#!kickstart
# AlmaLinux 9 — generisches Basis-Kickstart
# Hostname + weitere Konfiguration via Ansible

# Installation source
url --mirrorlist="https://mirrors.almalinux.org/mirrorlist/9/baseos"
repo --name="appstream" --mirrorlist="https://mirrors.almalinux.org/mirrorlist/9/appstream"

# Language + Keyboard
lang en_US.UTF-8
keyboard --vckeymap=ch --xlayouts=ch

# Timezone
timezone Europe/Zurich --utc

# Network (DHCP — Hostname wird per Ansible gesetzt)
network --bootproto=dhcp --onboot=yes --hostname=localhost

# Root-Account gesperrt — Auth nur via SSH-Key (ansible user)
rootpw --lock

# ansible user
user --name=ansible --groups=wheel --gecos="Ansible" --shell=/bin/bash
sshkey --username=ansible "{{ netboot_ssh_public_key }}"

# SELinux + Firewall
selinux --enforcing
firewall --enabled --service=ssh

# Bootloader
bootloader --location=mbr

# Disk (LVM + XFS)
# TrueNAS VMs: VirtIO → vda
ignoredisk --only-use=vda
clearpart --all --initlabel --drives=vda

part /boot/efi --fstype=efi  --size=512  --ondisk=vda
part /boot     --fstype=xfs  --size=1024 --ondisk=vda
part pv.01     --size=1 --grow           --ondisk=vda

volgroup almalinux pv.01
logvol /    --vgname=almalinux --name=root --fstype=xfs  --size=1 --grow
logvol swap --vgname=almalinux --name=swap --fstype=swap --recommended

# Packages
%packages
@^minimal-environment
qemu-guest-agent
git
curl
vim
-iwl*firmware
%end

# Post-install
%post
# qemu-guest-agent aktivieren
systemctl enable qemu-guest-agent

# Passwordless sudo für ansible
echo "ansible ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ansible
chmod 440 /etc/sudoers.d/ansible

# SSH Password-Auth deaktivieren
sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
%end

reboot
