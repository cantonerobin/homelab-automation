#!ipxe
# MAC-basiertes automatisches Booten
# Bekannte MACs booten direkt — unbekannte MACs: normales netboot.xyz Menü

{% for host in netboot_hosts %}
{% if host.kickstart_url %}
iseq ${mac} {{ host.mac }} && chain {{ netboot_http_base }}/boot-{{ host.name }}.ipxe ||
{% endif %}
{% endfor %}

# Unbekannte MAC → normales netboot.xyz Menü
exit 0
