# AlmaLinux 9 Kickstart — mediastack VM
# Served via: http://192.168.10.156:8080/mediastack.ks

# Installation source
url --mirrorlist="https://mirrors.almalinux.org/mirrorlist/9/baseos"
repo --name="appstream" --mirrorlist="https://mirrors.almalinux.org/mirrorlist/9/appstream"

# Language + Keyboard
lang en_US.UTF-8
keyboard --vckeymap=ch --xlayouts=ch

# Timezone
timezone Europe/Zurich --utc

# Network
network --bootproto=dhcp --onboot=yes --hostname=mediastack

# Root account locked — only ansible user via SSH key
rootpw --lock

# ansible user
user --name=ansible --groups=wheel --gecos="Ansible" --shell=/bin/bash
sshkey --username=ansible "{{ netboot_ssh_public_key }}"

# SELinux + Firewall
selinux --enforcing
firewall --enabled --service=ssh

# Bootloader
bootloader --location=mbr --boot-drive=sda

# Disk
clearpart --all --initlabel --drives=sda

# Partitioning — btrfs
part /boot/efi --fstype=efi  --size=512  --ondrive=sda
part /boot     --fstype=xfs  --size=1024 --ondrive=sda
part btrfs.01  --size=1 --grow           --ondrive=sda

btrfs none --label=almalinux btrfs.01
btrfs /     --subvol --name=root LABEL=almalinux
btrfs /home --subvol --name=home LABEL=almalinux

# Packages
%packages
@^minimal-environment
qemu-guest-agent
git
curl
vim
-iwl*firmware
%end

# Post-install
%post
# qemu-guest-agent aktivieren
systemctl enable qemu-guest-agent

# Passwordless sudo für ansible
echo "ansible ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ansible
chmod 440 /etc/sudoers.d/ansible

# SSH Password-Auth deaktivieren
sed -i 's/^#PasswordAuthentication yes/PasswordAuthentication no/' /etc/ssh/sshd_config
sed -i 's/^PasswordAuthentication yes/PasswordAuthentication no/'  /etc/ssh/sshd_config
%end

reboot
